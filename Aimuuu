<!DOCTYPE html>
<html>
<head>
<title>Digital Marketing Workshop Registration</title>
</head>

<body>

<h1>Digital Marketing Workshop</h1>

<h2>Event Information</h2>

<ul>
<li><b>Date:</b> 20 April 2026</li>
<li><b>Time:</b> 10:00 AM – 1:00 PM</li>
<li><b>Venue:</b> College Seminar Hall</li>
<li><b>Organizer:</b> Marketing Department</li>
</ul>

<hr>

<h2>Event Registration Form</h2>

<form>

<fieldset>
<legend>Personal Details</legend>

<label>Name:</label><br>
<input type="text" name="name"><br><br>

<label>Email:</label><br>
<input type="email" name="email"><br><br>

<label>Date of Birth:</label><br>
<input type="date" name="dob"><br><br>

</fieldset>

<br>

<fieldset>
<legend>Event Details</legend>

<label>Event Selection:</label><br>
<select name="event">
<option>Digital Marketing Basics</option>
<option>Social Media Marketing</option>
<option>SEO Techniques</option>
<option>Content Marketing</option>
</select>

<br><br>

<label>Mode of Participation:</label><br>

<input type="radio" name="mode"> Online<br>
<input type="radio" name="mode"> Offline<br>

</fieldset>

<br>

<fieldset>
<legend>Additional Information</legend>

<label>Upload ID Proof:</label><br>
<input type="file" name="idproof"><br><br>

<label>Comments / Expectations:</label><br>
<textarea rows="4" cols="40" name="comments"></textarea>

</fieldset>

<br>

<label>
<input type="checkbox"> I confirm that the above details are correct.
</label>

<br><br>

<input type="submit" value="Submit">
<input type="reset" value="Reset">

</form>

<hr>
<Footer>
<p>© 2026 Digital Marketing Workshop</p>
</footer>

</body>
</html>
